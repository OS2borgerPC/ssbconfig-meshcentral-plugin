<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{pluginName}}</title>
  <link rel="stylesheet" href="https://unpkg.com/@jsonforms/vanilla-renderers@3.3.0/lib/vanilla.css" />
  <style>
    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, sans-serif;
      background: #f5f7fb;
      color: #1c2430;
    }

    .page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 18px;
    }

    .panel {
      background: #ffffff;
      border: 1px solid #d8e0ea;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 16px;
      box-shadow: 0 1px 2px rgba(20, 29, 45, 0.05);
    }

    .row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 10px;
    }

    .row label {
      min-width: 180px;
      font-weight: 600;
    }

    .row input[type="text"],
    .row select {
      min-width: 280px;
      padding: 8px;
      border: 1px solid #c7d2df;
      border-radius: 6px;
      background: #fff;
    }

    .actions {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-top: 14px;
    }

    .actions button {
      padding: 10px 16px;
      border-radius: 6px;
      border: 1px solid #0b5;
      background: #0b5;
      color: white;
      font-weight: 600;
      cursor: pointer;
    }

    .actions button[disabled] {
      cursor: not-allowed;
      opacity: 0.65;
    }

    .status {
      padding: 8px 10px;
      border-radius: 6px;
      font-size: 13px;
    }

    .status.error {
      background: #ffeaea;
      color: #8a1e1e;
      border: 1px solid #f2bcbc;
    }

    .status.success {
      background: #eaf9ef;
      color: #1f6b33;
      border: 1px solid #b8e5c5;
    }

    .mono {
      font-family: "Courier New", monospace;
      font-size: 12px;
      overflow-wrap: anywhere;
    }

    .mapping-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 10px;
    }

    @media (max-width: 720px) {
      .row label {
        min-width: 100%;
      }

      .row input[type="text"],
      .row select {
        min-width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="panel">
      <h2>{{pluginName}}</h2>
      <p>
        Edit config using JSON Schema and UI Schema, map config domains to MeshCentral domains,
        upload assets, and commit all changes directly to GitHub on save.
      </p>
      <p class="mono" id="repoInfo"></p>
    </div>

    <div id="app"></div>
  </div>

  <script type="module">
    import React, { useEffect, useMemo, useState } from 'https://esm.sh/react@18.3.1';
    import { createRoot } from 'https://esm.sh/react-dom@18.3.1/client';
    import { JsonForms } from 'https://esm.sh/@jsonforms/react@3.3.0';
    import { vanillaRenderers, vanillaCells } from 'https://esm.sh/@jsonforms/vanilla-renderers@3.3.0';
    import Ajv from 'https://esm.sh/ajv@8.17.1';

    const bootstrap = {
      meshDomains: {{{meshDomainsJson}}}
    };

    function App() {
      const [loading, setLoading] = useState(true);
      const [saving, setSaving] = useState(false);
      const [status, setStatus] = useState(null);
      const [repoInfo, setRepoInfo] = useState('');
      const [schema, setSchema] = useState(null);
      const [uischema, setUiSchema] = useState(null);
      const [data, setData] = useState({});
      const [domainMap, setDomainMap] = useState({});
      const [assetDomain, setAssetDomain] = useState('');
      const [selectedFiles, setSelectedFiles] = useState([]);
      const [commitMessage, setCommitMessage] = useState('Update config and assets from MeshCentral plugin');

      useEffect(() => {
        fetchBootstrap();
      }, []);

      const configDomainOptions = useMemo(() => {
        if (!data || !data.domains || typeof data.domains !== 'object') {
          return [];
        }
        return Object.keys(data.domains);
      }, [data]);

      async function fetchBootstrap() {
        setLoading(true);
        setStatus(null);
        try {
          const response = await fetch('/pluginadmin.ashx?pin=ssbconfig&api=bootstrap&user=1');
          const payload = await response.json();
          if (!response.ok) {
            throw new Error(payload.error || 'Failed to load plugin bootstrap data');
          }

          setSchema(payload.schema);
          setUiSchema(payload.uischema);
          setData(payload.configData || {});

          const defaultMap = {};
          const sourceDomainNames = payload.configData && payload.configData.domains
            ? Object.keys(payload.configData.domains)
            : [];

          (payload.meshDomains || []).forEach((meshDomain) => {
            if (sourceDomainNames.includes(meshDomain)) {
              defaultMap[meshDomain] = meshDomain;
            }
          });
          setDomainMap(defaultMap);
          if (payload.meshDomains && payload.meshDomains.length > 0) {
            setAssetDomain(payload.meshDomains[0]);
          }

          const info = payload.configRepo
            ? payload.configRepo.owner + '/' + payload.configRepo.repo + ' @ ' + payload.configRepo.branch + ' :: ' + payload.configRepo.filePath
            : '';
          setRepoInfo(info);
          document.getElementById('repoInfo').innerText = info;
        } catch (error) {
          setStatus({ type: 'error', message: error.message || 'Bootstrap failed' });
        } finally {
          setLoading(false);
        }
      }

      function updateDomainMap(meshDomain, configDomain) {
        setDomainMap((prev) => {
          const next = { ...prev };
          if (!configDomain) {
            delete next[meshDomain];
          } else {
            next[meshDomain] = configDomain;
          }
          return next;
        });
      }

      function onFileSelection(evt) {
        const files = Array.from(evt.target.files || []);
        setSelectedFiles(files);
      }

      async function toAssetPayload(files) {
        const results = [];
        for (const file of files) {
          const contentBase64 = await readFileAsBase64(file);
          const relativePath = file.webkitRelativePath || file.name;
          results.push({
            path: relativePath,
            contentBase64: contentBase64
          });
        }
        return results;
      }

      async function onSave() {
        setSaving(true);
        setStatus(null);

        try {
          const ajv = new Ajv({ allErrors: true, strict: false });
          const validate = ajv.compile(schema);
          const valid = validate(data);
          if (!valid) {
            const text = (validate.errors || [])
              .map((e) => (e.instancePath || '/') + ' ' + e.message)
              .join('\n');
            throw new Error('Validation failed:\n' + text);
          }

          const assets = await toAssetPayload(selectedFiles);
          if (assets.length > 0 && !assetDomain) {
            throw new Error('Select target MeshCentral domain for assets.');
          }
          const response = await fetch('/pluginadmin.ashx?pin=ssbconfig&api=save&user=1', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              configData: data,
              domainMap,
              assets,
              assetDomain,
              commitMessage,
            })
          });

          const result = await response.json();
          if (!response.ok || result.error) {
            throw new Error(result.error || 'Save failed');
          }

          setStatus({
            type: 'success',
            message: 'Committed to GitHub. Commit: ' + result.commitSha + ' (' + result.branch + ')'
          });
          setSelectedFiles([]);
        } catch (error) {
          setStatus({ type: 'error', message: error.message || 'Save failed' });
        } finally {
          setSaving(false);
        }
      }

      if (loading) {
        return React.createElement('div', { className: 'panel' }, 'Loading schema, ui schema, and config...');
      }

      if (!schema) {
        return React.createElement('div', { className: 'panel status error' }, 'Schema missing.');
      }

      return React.createElement(
        React.Fragment,
        null,
        React.createElement(
          'div',
          { className: 'panel' },
          React.createElement('h3', null, 'Domain Mapping'),
          React.createElement(
            'p',
            null,
            'Map config domains to MeshCentral domains. Mapping is applied on save before commit.'
          ),
          React.createElement(
            'div',
            { className: 'mapping-grid' },
            (bootstrap.meshDomains || []).map((meshDomain) =>
              React.createElement(
                'div',
                { className: 'row', key: meshDomain },
                React.createElement('label', null, meshDomain),
                React.createElement(
                  'select',
                  {
                    value: domainMap[meshDomain] || '',
                    onChange: (e) => updateDomainMap(meshDomain, e.target.value)
                  },
                  React.createElement('option', { value: '' }, '-- no mapping --'),
                  configDomainOptions.map((name) =>
                    React.createElement('option', { value: name, key: name }, name)
                  )
                )
              )
            )
          )
        ),
        React.createElement(
          'div',
          { className: 'panel' },
          React.createElement('h3', null, 'Config Form'),
          React.createElement(JsonForms, {
            schema,
            uischema,
            data,
            renderers: vanillaRenderers,
            cells: vanillaCells,
            validationMode: 'NoValidation',
            onChange: ({ data: nextData }) => setData(nextData)
          })
        ),
        React.createElement(
          'div',
          { className: 'panel' },
          React.createElement('h3', null, 'Assets + Commit'),
          React.createElement(
            'div',
            { className: 'row' },
            React.createElement('label', null, 'Assets target domain'),
            React.createElement(
              'select',
              {
                value: assetDomain,
                onChange: (e) => setAssetDomain(e.target.value)
              },
              React.createElement('option', { value: '' }, '-- select domain --'),
              (bootstrap.meshDomains || []).map((meshDomain) =>
                React.createElement('option', { key: meshDomain, value: meshDomain }, meshDomain)
              )
            )
          ),
          React.createElement(
            'div',
            { className: 'mono', style: { marginBottom: '10px' } },
            assetDomain ? ('Assets are committed to: assets/' + assetDomain + '/...') : 'Assets path: assets/<domain>/...'
          ),
          React.createElement(
            'div',
            { className: 'row' },
            React.createElement('label', null, 'Upload files or folder'),
            React.createElement('input', {
              type: 'file',
              multiple: true,
              webkitdirectory: 'true',
              onChange: onFileSelection
            })
          ),
          selectedFiles.length > 0
            ? React.createElement(
                'div',
                { className: 'mono' },
                'Selected assets: ' + selectedFiles.map((f) => f.webkitRelativePath || f.name).join(', ')
              )
            : null,
          React.createElement(
            'div',
            { className: 'row' },
            React.createElement('label', null, 'Commit message'),
            React.createElement('input', {
              type: 'text',
              value: commitMessage,
              onChange: (e) => setCommitMessage(e.target.value)
            })
          ),
          React.createElement(
            'div',
            { className: 'actions' },
            React.createElement(
              'button',
              { onClick: onSave, disabled: saving },
              saving ? 'Saving...' : 'Validate + Commit to GitHub'
            ),
            React.createElement(
              'button',
              {
                onClick: fetchBootstrap,
                disabled: saving,
                style: {
                  borderColor: '#246',
                  background: '#246'
                }
              },
              'Reload from GitHub'
            )
          ),
          status
            ? React.createElement(
                'div',
                { className: 'status ' + status.type, style: { marginTop: '10px', whiteSpace: 'pre-wrap' } },
                status.message
              )
            : null,
          repoInfo
            ? React.createElement('div', { className: 'mono', style: { marginTop: '8px' } }, repoInfo)
            : null
        )
      );
    }

    function readFileAsBase64(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => {
          const result = String(reader.result || '');
          const idx = result.indexOf(',');
          resolve(idx >= 0 ? result.substring(idx + 1) : result);
        };
        reader.onerror = () => reject(new Error('Failed to read file: ' + file.name));
        reader.readAsDataURL(file);
      });
    }

    const root = createRoot(document.getElementById('app'));
    root.render(React.createElement(App));
  </script>
</body>
</html>
